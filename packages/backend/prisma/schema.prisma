generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  avatarUrl    String?
  provider     String?  // "google" | "microsoft" | "local"
  providerId   String?
  plan         Plan     @default(FREE)
  trialUsed    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Tier model: 'free' | 'business'
  tier                   String    @default("free")
  teamId                 String?
  documentsUsedThisMonth Int       @default(0)
  documentsResetAt       DateTime?

  subscription Subscription?
  usage        Usage[]
  apiKeys      ApiKey[]
  orgMembers   OrganizationMember[]
  team         Team?     @relation(fields: [teamId], references: [id])
  auditEvents  AuditEvent[]

  @@index([email])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  members   User[]
}

model AuditEvent {
  id           String   @id @default(uuid())
  userId       String
  teamId       String?
  action       String   // 'anonymize' | 'decrypt'
  documentHash String
  tokensCount  Int
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
  @@index([userId, createdAt])
}

model DemoRequest {
  id             String   @id @default(uuid())
  name           String
  email          String
  company        String
  teamSize       String
  industry       String
  message        String?
  calendlyBooked Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  plan                  Plan
  status                String    // "active" | "canceled" | "past_due" | "trialing"
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  yokassaSubscriptionId String?
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean   @default(false)
  isTrial               Boolean   @default(false)
  trialEndsAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Usage {
  id        String   @id @default(cuid())
  userId    String
  period    String   // "2025-01" format
  requests  Int      @default(0)
  chars     BigInt   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId, period])
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  keyHash     String    @unique
  keyPrefix   String    // first 8 chars for display
  scopes      String[]  @default(["anonymize"])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  plan      Plan     @default(BUSINESS)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members OrganizationMember[]
  license LicenseKey?
}

model OrganizationMember {
  id     String @id @default(cuid())
  orgId  String
  userId String
  role   String @default("member") // "owner" | "admin" | "member"

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model LicenseKey {
  id          String    @id @default(cuid())
  orgId       String    @unique
  key         String    @unique
  seats       Int       @default(10)
  validUntil  DateTime
  issuedAt    DateTime  @default(now())
  revokedAt   DateTime?
  offlineMode Boolean   @default(true)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model BusinessLead {
  id             String   @id @default(cuid())
  companyName    String
  role           String
  country        String
  industry       String
  expectedVolume String
  email          String
  message        String?
  status         LeadStatus @default(NEW)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([email])
  @@index([status])
}

model ProWaitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("en")
  source    String   @default("pricing_page")
  createdAt DateTime @default(now())

  @@index([email])
}

enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}
