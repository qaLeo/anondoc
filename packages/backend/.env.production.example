# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/anondoc  # Railway PostgreSQL URL (auto-filled by plugin)

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@host:6379               # Railway Redis URL (auto-filled by plugin)

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=                          # минимум 64 символа — openssl rand -hex 32
JWT_REFRESH_SECRET=                  # минимум 64 символа — openssl rand -hex 32

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...        # Stripe Dashboard → Developers → API keys
STRIPE_WEBHOOK_SECRET=whsec_...      # Stripe Dashboard → Developers → Webhooks
STRIPE_PRICE_PRO=price_...           # Stripe Dashboard → Products → PRO price ID
STRIPE_PRICE_BUSINESS=price_...      # Stripe Dashboard → Products → Business price ID

# ── ЮKassa ───────────────────────────────────────────────────────────────────
YUKASSA_SHOP_ID=                     # ЮKassa личный кабинет → Настройки магазина
YUKASSA_SECRET_KEY=                  # ЮKassa личный кабинет → Ключи API

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...                # resend.com → API Keys

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://anondoc.ru      # Домен фронтенда (для CORS и редиректов)
ALLOWED_ORIGINS=https://anondoc.ru,https://www.anondoc.ru

NODE_ENV=production
PORT=3000
LOG_LEVEL=info
