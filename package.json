{
  "name": "anondoc-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm --filter @anondoc/web dev",
    "dev:backend": "pnpm --filter @anondoc/backend dev",
    "build": "pnpm --filter @anondoc/engine build && pnpm --filter @anondoc/backend build && pnpm --filter @anondoc/web build",
    "build:engine": "pnpm --filter @anondoc/engine build",
    "build:web": "pnpm --filter @anondoc/web build",
    "vercel-build": "pnpm run build:engine && pnpm run build:web",
    "test": "pnpm -r test",
    "test:engine": "pnpm --filter @anondoc/engine test",
    "test:web": "pnpm --filter @anondoc/web test",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @anondoc/backend db:migrate",
    "db:generate": "pnpm --filter @anondoc/backend db:generate"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
